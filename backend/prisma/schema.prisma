generator client {
  provider = "prisma-client-js"
  output   = "../prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String?     // For email/password auth
  provider     String      @default("email") // "email" or "google"
  displayName  String?
  avatarUrl    String?
  createdAt    DateTime    @default(now())
  challenges   Challenge[]
  streaks      Streak[]
  dailyEntries  DailyEntry[]
  waterEntries WaterEntry[]
  dailyHabits  DailyHabit[]
  friendships  Friendship[] @relation("UserFriendships")
  friendedBy   Friendship[] @relation("FriendOfUser")
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  status    String   @default("pending") // "pending", "accepted", "declined"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("UserFriendships", fields: [userId], references: [id])
  friend    User     @relation("FriendOfUser", fields: [friendId], references: [id])

  @@unique([userId, friendId])
}


model Challenge {
  id          String       @id @default(uuid())
  userId      String
  name        String
  description String?
  type        String       // "water", "fitness", "productivity", "custom", etc.
  category    String       // "health", "fitness", "productivity", "skills", etc.
  duration    Int          // Number of days (e.g., 30)
  startDate   DateTime
  endDate     DateTime
  targetValue Float?       // Target value (e.g., 2.0 liters for water)
  unit        String?      // Unit of measurement (e.g., "liters", "minutes")
  color       String?      // Theme color for UI (hex code)
  icon        String?      // Icon/emoji for the challenge
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id])
  dailyTasks  DailyEntry[]
  streaks     Streak[]
  waterEntries WaterEntry[]
}

model WaterEntry {
  id          String   @id @default(uuid())
  userId      String
  challengeId String
  date        DateTime @default(now())
  amount      Float    // Amount consumed in liters
  targetAmount Float   // Target for that day (usually 2.0)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User      @relation(fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  
  @@unique([userId, challengeId, date])
}

model DailyEntry {
  id          String    @id @default(uuid())
  userId      String
  challengeId String
  dayNumber   Int       // Day 1, Day 2, etc.
  date        DateTime  // Actual calendar date
  completed   Boolean   @default(false)
  completedAt DateTime?
  notes       String?   // User notes for that day
  value       Float?    // For measurable challenges (e.g., 1.5 liters)
  
  user        User      @relation(fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  
  @@unique([userId, challengeId, dayNumber])
  @@unique([userId, challengeId, date])
}

model Streak {
  id            String   @id @default(uuid())
  userId        String
  challengeId   String
  length        Int      @default(0)
  missedDays    Int      @default(0)
  freezesUsed   Int      @default(0)
  lastUpdated   DateTime @default(now())
  isActive      Boolean  @default(true)
  // Track the last day the user completed (for recovery logic)
  lastCompletedDay Int   @default(0)

  user      User      @relation(fields: [userId], references: [id])
  challenge Challenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
}
model DailyHabit {
  id        String   @id @default(uuid())
  userId    String
  name      String   // e.g., "Cold Shower"
  completed Boolean  @default(false)
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, name, date])
}
